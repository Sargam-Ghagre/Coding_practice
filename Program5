import java.util.Scanner;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int num = sc.nextInt();
        int original = num;
        int rotated = 0;

        while (num > 0) {
            int rem = num % 10;

            // Rotate the digit
            if (rem == 0)
                rem = 0;
            else if (rem == 1)
                rem = 1;
            else if (rem == 8)
                rem = 8;
            else if (rem == 6)
                rem = 9;
            else if (rem == 9)
                rem = 6;
            else {
                System.out.println("Not a Strobogrammatic Number");
                return;
            }

            rotated = rotated * 10 + rem;
            num = num / 10;
        }

        if (rotated == original)
            System.out.println("Strobogrammatic Number");
        else
            System.out.println("Not a Strobogrammatic Number");
    }
}
