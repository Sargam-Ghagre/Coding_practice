import java.io.*;
import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int num = sc.nextInt();
        System.out.print(num);
        while(num > 1){
            if(num % 2 == 0){
                num = num / 2;
            }else{ 
                num = num * 3 + 1;
            }
            
            System.out.print(" " + num);
        }
    }
}
